# AI Incident Manager Environment Configuration
# Copy this file to .env and customize for your environment
# Do not commit real secrets to version control

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Database connection settings
# The database is used by the backend Go application

# Database host (use service name in Docker, localhost for development)
DB_HOST=localhost

# Database port (default: 5432)
DB_PORT=5432

# Database username (default: postgres)
DB_USER=postgres

# Database password (REQUIRED - set a strong password in production)
DB_PASSWORD=postgres

# Database name (default: incidentdb)
DB_NAME=incidentdb

# Database SSL mode (disable for local, require for production)
DB_SSLMODE=disable

# =============================================================================
# AI SERVICES CONFIGURATION
# =============================================================================
# Ollama AI service for embeddings and analysis

# Ollama service URL (use service name in Docker, localhost for development)
OLLAMA_URL=http://localhost:11434

# Default Ollama model to use (tinyllama, llama2, etc.)
OLLAMA_MODEL=tinyllama

# =============================================================================
# OBSERVABILITY CONFIGURATION
# =============================================================================
# Prometheus metrics service

# Prometheus service URL (use service name in Docker, localhost for development)
PROMETHEUS_URL=http://localhost:9090

# Loki log aggregation service

# Loki service URL (use service name in Docker, localhost for development)
LOKI_URL=http://localhost:3100

# =============================================================================
# GRAFANA CONFIGURATION
# =============================================================================
# Grafana dashboard and visualization

# Grafana service URL (use service name in Docker, localhost for development)
GRAFANA_URL=http://localhost:3001

# Grafana API key (optional - leave empty for development)
GRAFANA_API_KEY=

# Grafana admin username (default: admin)
GRAFANA_ADMIN_USER=admin

# Grafana admin password (REQUIRED - set a strong password in production)
GRAFANA_ADMIN_PASSWORD=admin

# Grafana domain (for production deployments)
GRAFANA_DOMAIN=localhost

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================
# Next.js frontend application

# Backend API URL for frontend consumption
# For local development: http://localhost:8081
# For Docker Compose: /api/backend (uses internal service communication)
NEXT_PUBLIC_API_URL=http://localhost:8081

# Grafana dashboard URL for frontend metrics display
NEXT_PUBLIC_GRAFANA_DASHBOARD_URL=http://localhost:3001

# =============================================================================
# BACKEND CONFIGURATION
# =============================================================================
# Go backend API server

# Server port (default: 8081)
SERVER_PORT=8081

# Gin framework mode (development, release, test)
GIN_MODE=release

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# CORS origins (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# API rate limiting (requests per minute)
API_RATE_LIMIT=100

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# JWT secret for authentication (generate a strong random string for production)
JWT_SECRET=your-jwt-secret-here

# Session secret for sessions (generate a strong random string for production)
SESSION_SECRET=your-session-secret-here

# =============================================================================
# DEVELOPMENT OVERRIDES
# =============================================================================
# These values override the defaults for local development
# Uncomment and modify as needed

# DB_HOST=localhost
# DB_PORT=5432
# OLLAMA_URL=http://localhost:11434
# NEXT_PUBLIC_API_URL=http://localhost:8081
# GRAFANA_URL=http://localhost:3001

# =============================================================================
# PRODUCTION EXAMPLES
# =============================================================================
# Example values for production deployment (replace with actual values)

# DB_HOST=your-db-host.com
# DB_PASSWORD=your-secure-db-password
# OLLAMA_URL=https://your-ollama-service.com
# PROMETHEUS_URL=https://your-prometheus.com
# LOKI_URL=https://your-loki-service.com
# GRAFANA_URL=https://your-grafana.com
# NEXT_PUBLIC_API_URL=https://your-api-domain.com
# CORS_ORIGINS=https://your-frontend-domain.com
# GIN_MODE=release
# LOG_LEVEL=warn
# JWT_SECRET=your-production-jwt-secret
# SESSION_SECRET=your-production-session-secret
