# Copy to .env.local for local development (Next.js loads .env.local automatically).
# No secrets here — values are exposed to the browser (NEXT_PUBLIC_*).

# Backend API base for Axios:
# - Local dev: absolute URL the browser can reach (no trailing slash).
NEXT_PUBLIC_API_URL=http://localhost:8081

# Docker Compose (frontend + api): use a same-origin proxy path in the **built** image instead:
#   NEXT_PUBLIC_API_URL=/api/backend
# and build with BACKEND_INTERNAL_URL=http://api:8080 (see docker-compose.yml).

# Deprecated alias (optional): same as NEXT_PUBLIC_API_URL
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# Grafana dashboard URL for incident metrics
# Example: https://grafana.example.com/d/your-dashboard-id
# Leave empty to disable metrics section
NEXT_PUBLIC_GRAFANA_DASHBOARD_URL=
